<div class="dashboard-container">
  <!-- Loading State -->
  <div *ngIf="loading" class="loading-overlay">
    <div class="loading-spinner"></div>
    <p>Loading your dashboard...</p>
  </div>

  <!-- Error State - Only show if critical, dismissible -->
  <div *ngIf="error && !loading" class="error-message" style="position: fixed; bottom: 20px; right: 20px; max-width: 400px; z-index: 1001; cursor: pointer;" (click)="error = ''">
    <p>{{ error }}</p>
    <small style="opacity: 0.7;">Click to dismiss</small>
  </div>

  <!-- Sidebar -->
  <aside class="sidebar">
    <!-- Bank Header Section -->
    <div class="bank-header">
      <div class="bank-logo">
        <span class="bank-name">NEOBANK</span>
        <span class="bank-tagline">YOUR PERFECT BANKING PARTNER</span>
      </div>
    </div>

    <!-- Search Bar -->
    <div class="search-container">
      <input 
        type="text" 
        placeholder="Search menu..." 
        class="search-input" 
        [(ngModel)]="searchQuery"
        (input)="onSidebarSearch()"
        (keyup.enter)="onSearchSubmit()"
      />
      <span class="search-clear" *ngIf="searchQuery" (click)="searchQuery = ''; onSidebarSearch()">&times;</span>
    </div>

    <!-- Navigation -->
    <nav class="navigation">
      <ul class="nav-list">
        <li class="nav-item" [hidden]="!matchesSidebarSearch('HOME')">
          <a (click)="selectFeature(null)" 
             [class.active]="!selectedFeature"
             class="nav-link">
            <span class="nav-icon">🏠</span>
            <span class="nav-text">HOME</span>
          </a>
        </li>
        <li class="nav-item" [hidden]="!matchesSidebarSearch('ACCOUNTS')">
          <a (click)="selectFeature('accounts')" 
             [class.active]="selectedFeature === 'accounts'"
             class="nav-link">
            <span class="nav-icon">📄</span>
            <span class="nav-text">ACCOUNTS</span>
          </a>
        </li>
        <li class="nav-item" [hidden]="!matchesSidebarSearch('TRANSFER FUNDS')">
          <a (click)="selectFeature('transferfunds')" 
             [class.active]="selectedFeature === 'transferfunds'"
             class="nav-link">
            <span class="nav-icon">💸</span>
            <span class="nav-text">TRANSFER FUNDS</span>
          </a>
        </li>
        <li class="nav-item" [hidden]="!matchesSidebarSearch('DEBIT CARDS')">
          <a (click)="selectFeature('card')" 
             [class.active]="selectedFeature === 'card'"
             class="nav-link">
            <span class="nav-icon">💳</span>
            <span class="nav-text">DEBIT CARDS</span>
          </a>
        </li>
        <li class="nav-item" [hidden]="!matchesSidebarSearch('CREDIT CARD')">
          <a (click)="selectFeature('credit-card')" 
             [class.active]="selectedFeature === 'credit-card'"
             class="nav-link">
            <span class="nav-icon">💳</span>
            <span class="nav-text">CREDIT CARD</span>
          </a>
        </li>
        <li class="nav-item" [hidden]="!matchesSidebarSearch('FASTag')">
          <a href="/website/fasttag" class="nav-link">
            <span class="nav-icon">🏷️</span>
            <span class="nav-text">FASTag</span>
          </a>
        </li>
        <li class="nav-item" [hidden]="!matchesSidebarSearch('TRANSACTIONS')">
          <a (click)="selectFeature('transaction')" 
             [class.active]="selectedFeature === 'transaction'"
             class="nav-link">
            <span class="nav-icon">🔄</span>
            <span class="nav-text">TRANSACTIONS</span>
          </a>
        </li>
        <li class="nav-item" [hidden]="!matchesSidebarSearch('AI ASSISTANT')">
          <a (click)="selectFeature('ai-assistant')" 
             [class.active]="selectedFeature === 'ai-assistant'"
             class="nav-link">
            <span class="nav-icon">🤖</span>
            <span class="nav-text">AI ASSISTANT</span>
          </a>
        </li>
        <li class="nav-item" [hidden]="!matchesSidebarSearch('MUTUAL FUNDS')">
          <a (click)="selectFeature('investments')" 
             [class.active]="selectedFeature === 'investments'"
             class="nav-link">
            <span class="nav-icon">📈</span>
            <span class="nav-text">MUTUAL FUNDS</span>
          </a>
        </li>
        <li class="nav-item" [hidden]="!matchesSidebarSearch('FIXED DEPOSITS')">
          <a (click)="selectFeature('fixed-deposits')" 
             [class.active]="selectedFeature === 'fixed-deposits'"
             class="nav-link">
            <span class="nav-icon">🏦</span>
            <span class="nav-text">FIXED DEPOSITS</span>
          </a>
        </li>
        <li class="nav-item" [hidden]="!matchesSidebarSearch('EMI MONITORING')">
          <a (click)="selectFeature('emi-monitoring')" 
             [class.active]="selectedFeature === 'emi-monitoring'"
             class="nav-link">
            <span class="nav-icon">📊</span>
            <span class="nav-text">EMI MONITORING</span>
          </a>
        </li>
        <li class="nav-item" [hidden]="!matchesSidebarSearch('LOANS')">
          <a (click)="selectFeature('loan')" 
             [class.active]="selectedFeature === 'loan'"
             class="nav-link">
            <span class="nav-icon">💰</span>
            <span class="nav-text">LOANS</span>
          </a>
        </li>
        <li class="nav-item" [hidden]="!matchesSidebarSearch('GOLD LOAN')">
          <a (click)="selectFeature('goldloan')" 
             [class.active]="selectedFeature === 'goldloan'"
             class="nav-link">
            <span class="nav-icon">🥇</span>
            <span class="nav-text">GOLD LOAN</span>
          </a>
        </li>
        <li class="nav-item" [hidden]="!matchesSidebarSearch('SUBSIDY CLAIM')">
          <a (click)="selectFeature('subsidy-claim')" 
             [class.active]="selectedFeature === 'subsidy-claim'"
             class="nav-link">
            <span class="nav-icon">🎓</span>
            <span class="nav-text">SUBSIDY CLAIM</span>
          </a>
        </li>
        <li class="nav-item" [hidden]="!matchesSidebarSearch('DEPOSIT REQUEST')">
          <a (click)="selectFeature('deposit-request')" 
             [class.active]="selectedFeature === 'deposit-request'"
             class="nav-link">
            <span class="nav-icon">🏧</span>
            <span class="nav-text">DEPOSIT REQUEST</span>
          </a>
        </li>
        <li class="nav-item" [hidden]="!matchesSidebarSearch('BILL PAYMENT')">
          <a (click)="selectFeature('bill-payment')" 
             [class.active]="selectedFeature === 'bill-payment'"
             class="nav-link">
            <span class="nav-icon">🧾</span>
            <span class="nav-text">BILL PAYMENT</span>
          </a>
        </li>
        <li class="nav-item" [hidden]="!matchesSidebarSearch('CHEQUE')">
          <a (click)="selectFeature('cheque')" 
             [class.active]="selectedFeature === 'cheque'"
             class="nav-link">
            <span class="nav-icon">📝</span>
            <span class="nav-text">CHEQUE</span>
          </a>
        </li>
        <li class="nav-item" [hidden]="!matchesSidebarSearch('KYC UPDATE')">
          <a (click)="selectFeature('kycupdate')" 
             [class.active]="selectedFeature === 'kycupdate'"
             class="nav-link">
            <span class="nav-icon">📑</span>
            <span class="nav-text">KYC UPDATE</span>
          </a>
        </li>
        <li class="nav-item" [hidden]="!matchesSidebarSearch('SCHEDULED PAYMENTS')">
          <a (click)="selectFeature('scheduled-payments')" 
             [class.active]="selectedFeature === 'scheduled-payments'"
             class="nav-link">
            <span class="nav-icon">📅</span>
            <span class="nav-text">SCHEDULED PAYMENTS</span>
          </a>
        </li>
        <li class="nav-item" [hidden]="!matchesSidebarSearch('SUPPORT TICKETS')">
          <a (click)="selectFeature('support-tickets')" 
             [class.active]="selectedFeature === 'support-tickets'"
             class="nav-link">
            <span class="nav-icon">🎫</span>
            <span class="nav-text">SUPPORT TICKETS</span>
          </a>
        </li>
        <li class="nav-item" [hidden]="!matchesSidebarSearch('BANK MESSAGES')">
          <a (click)="selectFeature('bank-messages')" 
             [class.active]="selectedFeature === 'bank-messages'"
             class="nav-link">
            <span class="nav-icon">📬</span>
            <span class="nav-text">BANK MESSAGES</span>
          </a>
        </li>
        <li class="nav-item" [hidden]="!matchesSidebarSearch('VIRTUAL CARD')">
          <a (click)="selectFeature('virtual-card')" 
             [class.active]="selectedFeature === 'virtual-card'"
             class="nav-link">
            <span class="nav-icon">💳</span>
            <span class="nav-text">VIRTUAL CARD</span>
          </a>
        </li>
        <li class="nav-item" [hidden]="!matchesSidebarSearch('BENEFICIARIES')">
          <a (click)="selectFeature('beneficiary-management')" 
             [class.active]="selectedFeature === 'beneficiary-management'"
             class="nav-link">
            <span class="nav-icon">👥</span>
            <span class="nav-text">BENEFICIARIES</span>
          </a>
        </li>
        <li class="nav-item" [hidden]="!matchesSidebarSearch('INSURANCE')">
          <a (click)="goToInsurance()"
             class="nav-link">
            <span class="nav-icon">🛡️</span>
            <span class="nav-text">INSURANCE</span>
          </a>
        </li>
        <li class="nav-item" [hidden]="!matchesSidebarSearch('MY PROFILE')">
          <a (click)="goToProfile()" 
             class="nav-link">
            <span class="nav-icon">👤</span>
            <span class="nav-text">MY PROFILE</span>
          </a>
        </li>
      </ul>
    </nav>
  </aside>

  <!-- Main Content -->
  <div class="main-content">
    <!-- Header -->
    <header class="main-header">
      <div class="header-content">
        <h1 class="welcome-title">Welcome {{ username }} 🏦</h1>
        <div class="fasttag-summary" style="margin-top:8px;">
          <a href="/website/fasttag" style="text-decoration:none;color:inherit;">
            <small>FASTag: </small>
            <strong>{{ fasttagCount }} active</strong>
            <small style="margin-left:10px">Balance: ₹{{ fasttagBalance }}</small>
          </a>
          <a href="/website/fasttag-apply" style="margin-left:12px;font-size:12px">Apply</a>
        </div>
        <div class="header-actions">
          <div class="session-info">
            <div class="session-item">
              <span class="session-label">Login:</span>
              <span class="session-value">{{ formatDateTime(loginTime) }}</span>
            </div>
            <div class="session-item">
              <span class="session-label">Session:</span>
              <span class="session-value duration">{{ sessionDuration }}</span>
            </div>
          </div>
          <div class="balance-display">
            <span class="balance-label">Balance:</span>
            <span class="balance-amount">₹{{ currentBalance | number:'1.2-2' }}</span>
          </div>
          <button (click)="goToProfile()" class="profile-btn"> Profile</button>
          <button (click)="logout()" class="logout-btn">Logout</button>
        </div>
      </div>
    </header>

    <!-- Content Area -->
    <div class="content-area">
      <div *ngIf="!selectedFeature" class="welcome-message">
        <div class="welcome-card">
          <h2>Welcome to NeoBank Dashboard</h2>
          <p>Select a feature from the sidebar to get started</p>
          
          <div class="feature-grid">
            <div class="feature-card" (click)="selectFeature('transferfunds')">
              <span class="feature-icon">💸</span>
              <h3>Transfer Funds</h3>
              <p>Send money to other accounts</p>
            </div>
            <div class="feature-card" (click)="selectFeature('deposit-request')">
              <span class="feature-icon">🏧</span>
              <h3>Deposit</h3>
              <p>Submit a deposit request</p>
            </div>
            <div class="feature-card" (click)="selectFeature('card')">
              <span class="feature-icon">💳</span>
              <h3>Card Management</h3>
              <p>Manage your cards</p>
            </div>
            <div class="feature-card" (click)="selectFeature('transaction')">
              <span class="feature-icon">🔄</span>
              <h3>Transactions</h3>
              <p>View transaction history</p>
            </div>
            <div class="feature-card" (click)="selectFeature('kycupdate')">
              <span class="feature-icon">📑</span>
              <h3>KYC Update</h3>
              <p>Update your information</p>
            </div>
            <div class="feature-card" (click)="selectFeature('loan')">
              <span class="feature-icon">💰</span>
              <h3>Loans</h3>
              <p>Apply for loans</p>
            </div>
            <div class="feature-card" (click)="selectFeature('ml-loan-prediction')">
              <span class="feature-icon">🤖</span>
              <h3>ML Loan Approval</h3>
              <p>AI-powered loan approval prediction</p>
            </div>
            <div class="feature-card" (click)="selectFeature('cheque')">
              <span class="feature-icon">📝</span>
              <h3>Cheque</h3>
              <p>Manage cheque leaves</p>
            </div>
            <div class="feature-card" (click)="selectFeature('goldloan')">
              <span class="feature-icon">🥇</span>
              <h3>Gold Loan</h3>
              <p>Apply for gold loan</p>
            </div>
            <div class="feature-card" (click)="selectFeature('investments')">
              <span class="feature-icon">📈</span>
              <h3>Investments</h3>
              <p>Mutual funds & SIP</p>
            </div>
            <div class="feature-card" (click)="selectFeature('fixed-deposits')">
              <span class="feature-icon">🏦</span>
              <h3>Fixed Deposits</h3>
              <p>Open FDs online</p>
            </div>
            <div class="feature-card" (click)="selectFeature('emi-monitoring')">
              <span class="feature-icon">📊</span>
              <h3>EMI Monitoring</h3>
              <p>Track your EMIs</p>
            </div>
            <div class="feature-card" (click)="selectFeature('scheduled-payments')">
              <span class="feature-icon">📅</span>
              <h3>Scheduled Payments</h3>
              <p>Automate recurring bills</p>
            </div>
            <div class="feature-card" (click)="selectFeature('virtual-card')">
              <span class="feature-icon">💳</span>
              <h3>Virtual Card</h3>
              <p>Instant virtual debit cards</p>
            </div>
            <div class="feature-card" (click)="selectFeature('beneficiary-management')">
              <span class="feature-icon">👥</span>
              <h3>Beneficiaries</h3>
              <p>Manage your payees</p>
            </div>
            <div class="feature-card" (click)="goToInsurance()">
              <span class="feature-icon">🛡️</span>
              <h3>Insurance</h3>
              <p>Apply & manage policies</p>
            </div>
          </div>
        </div>
      </div>
      
      <div *ngIf="selectedFeature" class="feature-content">
        <!-- AI Assistant Component -->
        <app-ai-assistant *ngIf="selectedFeature === 'ai-assistant'"></app-ai-assistant>
        
        <!-- ML Loan Prediction Component -->
        <div *ngIf="selectedFeature === 'ml-loan-prediction'" class="ml-loan-prediction-section">
          <div class="feature-header">
            <h2>🤖 ML-Based Loan Approval Prediction</h2>
            <p>Get instant AI-powered loan approval prediction based on your PAN card and financial profile</p>
          </div>
          
          <div class="ml-prediction-form" *ngIf="!predictionResult">
            <div class="form-group">
              <label>PAN Card Number <span class="required">*</span></label>
              <input 
                type="text" 
                [(ngModel)]="mlPredictionForm.pan" 
                placeholder="Enter PAN number"
                maxlength="10"
                class="form-input"
              />
            </div>
            
            <div class="form-group">
              <label>Loan Type <span class="required">*</span></label>
              <select [(ngModel)]="mlPredictionForm.loanType" class="form-input">
                <option value="">Select Loan Type</option>
                <option value="Personal Loan">Personal Loan</option>
                <option value="Education Loan">Education Loan</option>
                <option value="Home Loan">Home Loan</option>
                <option value="Car Loan">Car Loan</option>
              </select>
            </div>
            
            <div class="form-group">
              <label>Requested Amount (₹) <span class="required">*</span></label>
              <input 
                type="number" 
                [(ngModel)]="mlPredictionForm.amount" 
                placeholder="Enter loan amount"
                min="10000"
                class="form-input"
              />
            </div>
            
            <div class="form-group">
              <label>Tenure (Months) <span class="required">*</span></label>
              <input 
                type="number" 
                [(ngModel)]="mlPredictionForm.tenure" 
                placeholder="Enter tenure in months"
                min="6"
                max="360"
                class="form-input"
              />
            </div>
            
            <button 
              class="predict-btn" 
              (click)="predictLoanApproval()"
              [disabled]="isPredicting || !isFormValid()"
            >
              <span *ngIf="!isPredicting">🔮 Predict Loan Approval</span>
              <span *ngIf="isPredicting">⏳ Predicting...</span>
            </button>
          </div>
          
          <div *ngIf="predictionResult" class="prediction-result">
            <div class="result-header">
              <h3>Prediction Result</h3>
              <button class="close-btn" (click)="clearPrediction()">×</button>
            </div>
            
            <div class="result-card" [ngClass]="getPredictionResultClass(predictionResult.predictionResult)">
              <div class="result-status">
                <span class="status-icon">{{ getStatusIcon(predictionResult.predictionResult) }}</span>
                <h4>{{ predictionResult.predictionResult }}</h4>
                <p class="probability">Approval Probability: {{ predictionResult.approvalPercentage || (predictionResult.approvalProbability ? Math.round(predictionResult.approvalProbability * 100) : 0) }}%</p>
              </div>
              
              <div class="result-details">
                <div class="detail-item">
                  <span class="label">CIBIL Score:</span>
                  <span class="value">{{ predictionResult.cibilScore || 'N/A' }}</span>
                  <span class="category" *ngIf="predictionResult.scoreCategory">({{ predictionResult.scoreCategory }})</span>
                </div>
                <div class="detail-item">
                  <span class="label">Interest Rate:</span>
                  <span class="value">{{ predictionResult.interestRate || 'N/A' }}<ng-container *ngIf="predictionResult.interestRate">% p.a.</ng-container></span>
                </div>
                <div class="detail-item">
                  <span class="label">Credit Limit:</span>
                  <span class="value">₹{{ (predictionResult.creditLimit || 0) | number:'1.0-0' }}</span>
                </div>
              </div>
              
              <div *ngIf="predictionResult.rejectionReason" class="rejection-reason">
                <h5>Rejection Reason:</h5>
                <p>{{ predictionResult.rejectionReason }}</p>
              </div>
              
              <div *ngIf="predictionResult.recommendations && predictionResult.recommendations.length > 0" class="recommendations">
                <h5>💡 Recommendations:</h5>
                <ul>
                  <li *ngFor="let rec of predictionResult.recommendations">{{ rec }}</li>
                </ul>
              </div>
            </div>
          </div>
        </div>

        <!-- Deposit Request Section -->
        <div *ngIf="selectedFeature === 'deposit-request'" class="deposit-section">
          <div class="feature-header">
            <h2>🏧 Deposit Request</h2>
            <button (click)="loadDepositRequests()" class="action-btn">Refresh</button>
          </div>

          <div class="deposit-form">
            <div class="form-row">
              <div class="form-group">
                <label>Amount (₹) <span class="required">*</span></label>
                <input type="number" [(ngModel)]="depositForm.amount" class="form-input" min="1" placeholder="Enter amount to deposit" />
              </div>
              <div class="form-group">
                <label>Method</label>
                <select [(ngModel)]="depositForm.method" class="form-input">
                  <option value="Cash">Cash</option>
                  <option value="Cheque">Cheque</option>
                  <option value="UPI">UPI</option>
                  <option value="Online Transfer">Online Transfer</option>
                </select>
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label>Reference Number</label>
                <input type="text" [(ngModel)]="depositForm.referenceNumber" class="form-input" placeholder="Slip/UTR/Reference number (optional)" />
              </div>
            </div>
            <div class="form-row">
              <div class="form-group full-width">
                <label>Note</label>
                <textarea [(ngModel)]="depositForm.note" class="form-textarea" rows="3" placeholder="Any note for the cashier/admin"></textarea>
              </div>
            </div>
            <div class="form-actions">
              <button class="btn-primary" (click)="submitDepositRequest()" [disabled]="isSubmittingDeposit">
                {{ isSubmittingDeposit ? 'Submitting...' : 'Submit Request' }}
              </button>
              <button class="btn-secondary" type="button" (click)="resetDepositForm()">Clear</button>
            </div>
            <div class="message success-message" *ngIf="depositMessage">{{ depositMessage }}</div>
            <div class="message error-message" *ngIf="depositError">{{ depositError }}</div>
          </div>

          <div class="deposit-requests">
            <h3>Recent Requests</h3>
            <div *ngIf="isLoadingDepositRequests" class="loading-state">Loading deposit requests...</div>
            <div *ngIf="!isLoadingDepositRequests && depositRequests.length === 0" class="empty-state">
              <p>No deposit requests found.</p>
            </div>
            <div *ngIf="!isLoadingDepositRequests && depositRequests.length > 0" class="deposit-list">
              <div *ngFor="let req of depositRequests" class="deposit-card" [ngClass]="req.status?.toLowerCase()">
                <div class="card-header">
                  <div>
                    <h4>₹{{ req.amount | number:'1.2-2' }} • {{ req.method }}</h4>
                    <p class="muted">Request ID: {{ req.requestId }}</p>
                  </div>
                  <span class="status-badge">{{ req.status }}</span>
                </div>
                <div class="card-body">
                  <p><strong>Note:</strong> {{ req.note || 'N/A' }}</p>
                  <p><strong>Reference:</strong> {{ req.referenceNumber || 'N/A' }}</p>
                  <p><strong>Created:</strong> {{ req.createdAt | date:'dd/MM/yyyy, h:mm a' }}</p>
                  <p *ngIf="req.processedAt"><strong>Processed:</strong> {{ req.processedAt | date:'dd/MM/yyyy, h:mm a' }}</p>
                  <p *ngIf="req.processedBy"><strong>Processed By:</strong> {{ req.processedBy }}</p>
                  <p *ngIf="req.rejectionReason" class="rejection">Reason: {{ req.rejectionReason }}</p>
                  <p *ngIf="req.resultingBalance != null"><strong>New Balance:</strong> ₹{{ req.resultingBalance | number:'1.2-2' }}</p>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Investments Section -->
        <div *ngIf="selectedFeature === 'investments'" class="investments-section">
          <div class="feature-header">
            <h2>📈 Investments (Mutual Funds)</h2>
            <button (click)="openInvestmentForm()" class="action-btn">+ New Investment</button>
          </div>
          
          <div *ngIf="isLoadingInvestments" class="loading-state">Loading investments...</div>
          
          <div *ngIf="!isLoadingInvestments && investments.length === 0" class="empty-state">
            <p>No investments found. Start investing today!</p>
          </div>
          
          <div *ngIf="!isLoadingInvestments && investments.length > 0" class="investments-list">
            <div *ngFor="let investment of investments" class="investment-card" [ngClass]="getInvestmentStatusClass(investment.status)">
              <div class="card-header">
                <h3>{{ investment.fundName || 'Mutual Fund' }}</h3>
                <span class="status-badge" [ngClass]="getInvestmentStatusClass(investment.status)">
                  {{ investment.status }}
                </span>
              </div>
              <div class="card-body">
                <div class="info-row">
                  <span class="label">Type:</span>
                  <span class="value">{{ investment.investmentType }}</span>
                </div>
                <div class="info-row">
                  <span class="label">Category:</span>
                  <span class="value">{{ investment.fundCategory || 'N/A' }}</span>
                </div>
                <div class="info-row">
                  <span class="label">Investment Amount:</span>
                  <span class="value">₹{{ investment.investmentAmount | number:'1.2-2' }}</span>
                </div>
                <div class="info-row">
                  <span class="label">Current Value:</span>
                  <span class="value">₹{{ investment.currentValue | number:'1.2-2' }}</span>
                </div>
                <div class="info-row" *ngIf="investment.units">
                  <span class="label">Units:</span>
                  <span class="value">{{ investment.units | number:'1.2-2' }}</span>
                </div>
                <div class="info-row" *ngIf="investment.returns">
                  <span class="label">Returns:</span>
                  <span class="value" [ngClass]="investment.returns >= 0 ? 'positive' : 'negative'">
                    {{ investment.returns }}%
                  </span>
                </div>
                <div class="info-row">
                  <span class="label">Date:</span>
                  <span class="value">{{ investment.investmentDate | date:'dd/MM/yyyy' }}</span>
                </div>
              </div>
              <div class="card-actions" *ngIf="investment.status === 'ACTIVE' || investment.status === 'APPROVED'">
                <button (click)="openMFForeclosureModal(investment)" class="btn-foreclose">Request Foreclosure</button>
              </div>
            </div>
          </div>
          
          <!-- Foreclosure History Section -->
          <div *ngIf="mfForeclosureHistory.length > 0" class="foreclosure-history-section" style="margin-top: 30px;">
            <h3>Foreclosure History</h3>
            <div *ngIf="isLoadingMFForeclosureHistory" class="loading-state">Loading foreclosure history...</div>
            <div *ngIf="!isLoadingMFForeclosureHistory" class="foreclosure-list">
              <div *ngFor="let foreclosure of mfForeclosureHistory" class="foreclosure-card" [ngClass]="getMFForeclosureStatusClass(foreclosure.status)">
                <div class="card-header">
                  <h4>{{ foreclosure.fundName }}</h4>
                  <span class="status-badge" [ngClass]="getMFForeclosureStatusClass(foreclosure.status)">
                    {{ foreclosure.status }}
                  </span>
                </div>
                <div class="card-body">
                  <div class="info-row">
                    <span class="label">Investment Amount:</span>
                    <span class="value">₹{{ foreclosure.investmentAmount | number:'1.2-2' }}</span>
                  </div>
                  <div class="info-row">
                    <span class="label">Current Value:</span>
                    <span class="value">₹{{ foreclosure.currentValue | number:'1.2-2' }}</span>
                  </div>
                  <div class="info-row">
                    <span class="label">Fine:</span>
                    <span class="value">₹{{ foreclosure.fine | number:'1.2-2' }}</span>
                  </div>
                  <div class="info-row">
                    <span class="label">Foreclosure Amount:</span>
                    <span class="value">₹{{ foreclosure.foreclosureAmount | number:'1.2-2' }}</span>
                  </div>
                  <div class="info-row">
                    <span class="label">Request Date:</span>
                    <span class="value">{{ foreclosure.requestDate | date:'dd/MM/yyyy HH:mm' }}</span>
                  </div>
                  <div class="info-row" *ngIf="foreclosure.approvalDate">
                    <span class="label">Approval Date:</span>
                    <span class="value">{{ foreclosure.approvalDate | date:'dd/MM/yyyy HH:mm' }}</span>
                  </div>
                  <div class="info-row" *ngIf="foreclosure.rejectionReason">
                    <span class="label">Rejection Reason:</span>
                    <span class="value">{{ foreclosure.rejectionReason }}</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Investment Form Modal -->
          <div *ngIf="showInvestmentForm" class="modal-overlay" (click)="closeInvestmentForm()">
            <div class="modal-content" (click)="$event.stopPropagation()">
              <div class="modal-header">
                <h3>New Investment Application</h3>
                <button (click)="closeInvestmentForm()" class="close-btn">×</button>
              </div>
              <div class="modal-body">
                <div class="form-group">
                  <label>Fund Name *</label>
                  <input type="text" [(ngModel)]="investmentForm.fundName" class="form-input" placeholder="e.g., HDFC Equity Fund" />
                </div>
                <div class="form-group">
                  <label>Fund Category *</label>
                  <select [(ngModel)]="investmentForm.fundCategory" class="form-input">
                    <option value="">Select Category</option>
                    <option value="Equity">Equity</option>
                    <option value="Debt">Debt</option>
                    <option value="Hybrid">Hybrid</option>
                    <option value="Liquid">Liquid</option>
                  </select>
                </div>
                <div class="form-group">
                  <label>Fund Scheme</label>
                  <select [(ngModel)]="investmentForm.fundScheme" class="form-input">
                    <option value="">Select Scheme</option>
                    <option value="Growth">Growth</option>
                    <option value="Dividend">Dividend</option>
                  </select>
                </div>
                <div class="form-group">
                  <label>Investment Amount (₹) *</label>
                  <input type="number" [(ngModel)]="investmentForm.investmentAmount" class="form-input" min="1000" />
                </div>
                <div class="form-group">
                  <label>
                    <input type="checkbox" [(ngModel)]="investmentForm.isSIP" />
                    This is a SIP (Systematic Investment Plan)
                  </label>
                </div>
                <div *ngIf="investmentForm.isSIP" class="form-group">
                  <label>SIP Amount (₹) *</label>
                  <input type="number" [(ngModel)]="investmentForm.sipAmount" class="form-input" min="500" />
                </div>
                <div *ngIf="investmentForm.isSIP" class="form-group">
                  <label>SIP Duration (Months) *</label>
                  <input type="number" [(ngModel)]="investmentForm.sipDuration" class="form-input" min="6" />
                </div>
              </div>
              <div class="modal-footer">
                <button (click)="closeInvestmentForm()" class="btn-secondary">Cancel</button>
                <button (click)="submitInvestment()" [disabled]="isSubmittingInvestment" class="btn-primary">
                  {{ isSubmittingInvestment ? 'Submitting...' : 'Submit Application' }}
                </button>
              </div>
            </div>
          </div>
          
          <!-- Foreclosure Modal -->
          <div *ngIf="showMFForeclosureModal" class="modal-overlay" (click)="closeMFForeclosureModal()">
            <div class="modal-content" (click)="$event.stopPropagation()">
              <div class="modal-header">
                <h3>Request Mutual Fund Foreclosure</h3>
                <button (click)="closeMFForeclosureModal()" class="close-btn">×</button>
              </div>
              <div class="modal-body">
                <div *ngIf="selectedInvestmentForForeclosure" class="foreclosure-info">
                  <h4>{{ selectedInvestmentForForeclosure.fundName }}</h4>
                  <div class="info-row">
                    <span class="label">Investment Amount:</span>
                    <span class="value">₹{{ selectedInvestmentForForeclosure.investmentAmount | number:'1.2-2' }}</span>
                  </div>
                  <div class="info-row">
                    <span class="label">Current Value:</span>
                    <span class="value">₹{{ selectedInvestmentForForeclosure.currentValue | number:'1.2-2' }}</span>
                  </div>
                </div>
                
                <div *ngIf="isCalculatingMFForeclosure" class="loading-state">
                  <p>Calculating foreclosure details...</p>
                </div>
                
                <div *ngIf="!isCalculatingMFForeclosure && mfForeclosureDetails && mfForeclosureDetails.success" class="foreclosure-details">
                  <div class="info-box">
                    <div class="info-row">
                      <span class="label">Fine Amount:</span>
                      <span class="value highlight">₹{{ mfForeclosureDetails.fine | number:'1.2-2' }}</span>
                    </div>
                    <div class="info-row">
                      <span class="label">Amount to be Credited:</span>
                      <span class="value highlight positive">₹{{ mfForeclosureDetails.foreclosureAmount | number:'1.2-2' }}</span>
                    </div>
                    <div class="info-note">
                      <p><strong>Note:</strong> A fine of ₹{{ mfForeclosureDetails.fine | number:'1.2-2' }} will be deducted from your current value. The remaining amount will be credited to your account after admin approval.</p>
                    </div>
                  </div>
                  
                  <div class="form-group">
                    <label>Reason for Foreclosure (Optional)</label>
                    <textarea [(ngModel)]="mfForeclosureRequestReason" class="form-input" rows="3" placeholder="Enter reason for foreclosure (optional)"></textarea>
                  </div>
                </div>
                
                <div *ngIf="!isCalculatingMFForeclosure && mfForeclosureDetails && !mfForeclosureDetails.success" class="error-message">
                  <p>{{ mfForeclosureDetails.message }}</p>
                </div>
              </div>
              <div class="modal-footer" *ngIf="mfForeclosureDetails && mfForeclosureDetails.success">
                <button (click)="closeMFForeclosureModal()" class="btn-secondary">Cancel</button>
                <button (click)="requestMFForeclosure()" [disabled]="isRequestingMFForeclosure" class="btn-primary">
                  {{ isRequestingMFForeclosure ? 'Submitting...' : 'Submit Request' }}
                </button>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Fixed Deposits Section -->
        <div *ngIf="selectedFeature === 'fixed-deposits'" class="fixed-deposits-section">
          <div class="feature-header">
            <h2>🏦 Fixed Deposits</h2>
            <button (click)="openFDForm()" class="action-btn">+ Open New FD</button>
          </div>
          
          <div *ngIf="isLoadingFDs" class="loading-state">Loading fixed deposits...</div>
          
          <div *ngIf="!isLoadingFDs && fixedDeposits.length === 0" class="empty-state">
            <p>No fixed deposits found. Open your first FD today!</p>
          </div>
          
          <div *ngIf="!isLoadingFDs && fixedDeposits.length > 0" class="fds-list">
            <div *ngFor="let fd of fixedDeposits" class="fd-card" [ngClass]="getFDStatusClass(fd.status)">
              <div class="card-header">
                <h3>FD Account: {{ fd.fdAccountNumber }}</h3>
                <span class="status-badge" [ngClass]="getFDStatusClass(fd.status)">
                  {{ fd.status }}
                </span>
              </div>
              <div class="card-body">
                <div class="info-row">
                  <span class="label">Principal Amount:</span>
                  <span class="value">₹{{ fd.principalAmount | number:'1.2-2' }}</span>
                </div>
                <div class="info-row">
                  <span class="label">Interest Rate:</span>
                  <span class="value">{{ fd.interestRate }}% p.a.</span>
                </div>
                <div class="info-row">
                  <span class="label">Tenure:</span>
                  <span class="value">{{ fd.tenure }} months</span>
                </div>
                <div class="info-row">
                  <span class="label">Maturity Amount:</span>
                  <span class="value highlight">₹{{ fd.maturityAmount | number:'1.2-2' }}</span>
                </div>
                <div class="info-row">
                  <span class="label">Interest Amount:</span>
                  <span class="value">₹{{ fd.interestAmount | number:'1.2-2' }}</span>
                </div>
                <div class="info-row">
                  <span class="label">Start Date:</span>
                  <span class="value">{{ fd.startDate | date:'dd/MM/yyyy' }}</span>
                </div>
                <div class="info-row">
                  <span class="label">Maturity Date:</span>
                  <span class="value">{{ fd.maturityDate | date:'dd/MM/yyyy' }}</span>
                </div>
                <div class="info-row">
                  <span class="label">Interest Payout:</span>
                  <span class="value">{{ fd.interestPayout }}</span>
                </div>
              </div>
              <div class="card-footer" *ngIf="fd.status === 'ACTIVE'">
                <button (click)="openForeclosureModal(fd)" class="btn-foreclosure">Foreclose FD</button>
                <button (click)="openTopUpModal(fd)" class="btn-topup">Increase Amount</button>
              </div>
            </div>
          </div>
          
          <!-- FD Form Modal -->
          <div *ngIf="showFDForm" class="modal-overlay" (click)="closeFDForm()">
            <div class="modal-content" (click)="$event.stopPropagation()">
              <div class="modal-header">
                <h3>Open New Fixed Deposit</h3>
                <button (click)="closeFDForm()" class="close-btn">×</button>
              </div>
              <div class="modal-body">
                <div class="form-group">
                  <label>Principal Amount (₹) *</label>
                  <input type="number" [(ngModel)]="fdForm.principalAmount" class="form-input" min="1000" />
                </div>
                <div class="form-group">
                  <label>Interest Rate (%) *</label>
                  <input type="number" [(ngModel)]="fdForm.interestRate" class="form-input" min="3" max="10" step="0.1" />
                </div>
                <div class="form-group">
                  <label>Tenure (Months) *</label>
                  <input type="number" [(ngModel)]="fdForm.tenure" class="form-input" min="6" max="120" />
                </div>
                <div class="form-group">
                  <label>Interest Payout *</label>
                  <select [(ngModel)]="fdForm.interestPayout" class="form-input">
                    <option value="At Maturity">At Maturity</option>
                    <option value="Monthly">Monthly</option>
                    <option value="Quarterly">Quarterly</option>
                  </select>
                </div>
                <div class="info-box">
                  <p><strong>Estimated Maturity Amount:</strong> 
                    ₹{{ (fdForm.principalAmount * Math.pow(1 + fdForm.interestRate/100, fdForm.tenure/12)) | number:'1.2-2' }}
                  </p>
                </div>
              </div>
              <div class="modal-footer">
                <button (click)="closeFDForm()" class="btn-secondary">Cancel</button>
                <button (click)="submitFD()" [disabled]="isSubmittingFD" class="btn-primary">
                  {{ isSubmittingFD ? 'Submitting...' : 'Submit Application' }}
                </button>
              </div>
            </div>
          </div>

          <!-- FD Foreclosure Modal -->
          <div *ngIf="showForeclosureModal" class="modal-overlay" (click)="closeForeclosureModal()">
            <div class="modal-content" (click)="$event.stopPropagation()">
              <div class="modal-header">
                <h3>Foreclose Fixed Deposit</h3>
                <button (click)="closeForeclosureModal()" class="close-btn">×</button>
              </div>
              <div class="modal-body">
                <div *ngIf="foreclosureDetails" class="foreclosure-details">
                  <div class="info-box">
                    <h4>Foreclosure Details</h4>
                    <div class="info-row">
                      <span class="label">Principal Amount:</span>
                      <span class="value">₹{{ foreclosureDetails.principalAmount | number:'1.2-2' }}</span>
                    </div>
                    <div class="info-row">
                      <span class="label">Interest Earned:</span>
                      <span class="value">₹{{ foreclosureDetails.interestEarned | number:'1.2-2' }}</span>
                    </div>
                    <div class="info-row">
                      <span class="label">Penalty ({{ foreclosureDetails.penaltyRate }}%):</span>
                      <span class="value danger">-₹{{ foreclosureDetails.penalty | number:'1.2-2' }}</span>
                    </div>
                    <div class="info-row highlight">
                      <span class="label">Closure Amount:</span>
                      <span class="value">₹{{ foreclosureDetails.closureAmount | number:'1.2-2' }}</span>
                    </div>
                    <div class="info-row">
                      <span class="label">Months Elapsed:</span>
                      <span class="value">{{ foreclosureDetails.monthsElapsed }}</span>
                    </div>
                    <div class="info-row">
                      <span class="label">Remaining Months:</span>
                      <span class="value">{{ foreclosureDetails.remainingMonths }}</span>
                    </div>
                  </div>
                  <p class="warning-text">⚠️ Premature closure will result in penalty charges. Are you sure you want to proceed?</p>
                </div>
                <div *ngIf="isLoadingForeclosure" class="loading-state">Calculating foreclosure details...</div>
              </div>
              <div class="modal-footer">
                <button (click)="closeForeclosureModal()" class="btn-secondary">Cancel</button>
                <button (click)="processForeclosure()" [disabled]="!foreclosureDetails || isProcessingForeclosure" class="btn-primary">
                  {{ isProcessingForeclosure ? 'Processing...' : 'Confirm Foreclosure' }}
                </button>
              </div>
            </div>
          </div>

          <!-- FD Top-up Modal -->
          <div *ngIf="showTopUpModal" class="modal-overlay" (click)="closeTopUpModal()">
            <div class="modal-content" (click)="$event.stopPropagation()">
              <div class="modal-header">
                <h3>Increase FD Amount (Top-up)</h3>
                <button (click)="closeTopUpModal()" class="close-btn">×</button>
              </div>
              <div class="modal-body">
                <div class="form-group">
                  <label>Additional Amount (₹) *</label>
                  <input type="number" [(ngModel)]="topUpAmount" class="form-input" min="1000" step="100" />
                </div>
                <div class="info-box" *ngIf="selectedFDForTopUp">
                  <p><strong>Current Principal:</strong> ₹{{ selectedFDForTopUp.principalAmount | number:'1.2-2' }}</p>
                  <p><strong>New Principal:</strong> ₹{{ (selectedFDForTopUp.principalAmount + (topUpAmount || 0)) | number:'1.2-2' }}</p>
                  <p><strong>Available Balance:</strong> ₹{{ currentBalance | number:'1.2-2' }}</p>
                </div>
              </div>
              <div class="modal-footer">
                <button (click)="closeTopUpModal()" class="btn-secondary">Cancel</button>
                <button (click)="processTopUp()" [disabled]="!topUpAmount || topUpAmount <= 0 || isProcessingTopUp" class="btn-primary">
                  {{ isProcessingTopUp ? 'Processing...' : 'Confirm Top-up' }}
                </button>
              </div>
            </div>
          </div>
        </div>
        
        <!-- EMI Monitoring Section -->
        <div *ngIf="selectedFeature === 'emi-monitoring'" class="emi-monitoring-section">
          <div class="feature-header">
            <h2>📊 EMI Monitoring</h2>
            <button (click)="loadEMIs()" class="action-btn">Refresh</button>
          </div>
          
          <!-- EMI Summary -->
          <div *ngIf="emiSummary" class="emi-summary-card">
            <h3>EMI Summary</h3>
            <div class="summary-grid">
              <div class="summary-item">
                <span class="summary-label">Total EMIs</span>
                <span class="summary-value">{{ emiSummary.totalEmis }}</span>
              </div>
              <div class="summary-item">
                <span class="summary-label">Paid</span>
                <span class="summary-value success">{{ emiSummary.paidEmis }}</span>
              </div>
              <div class="summary-item">
                <span class="summary-label">Pending</span>
                <span class="summary-value warning">{{ emiSummary.pendingEmis }}</span>
              </div>
              <div class="summary-item">
                <span class="summary-label">Overdue</span>
                <span class="summary-value danger">{{ emiSummary.overdueEmis }}</span>
              </div>
              <div class="summary-item">
                <span class="summary-label">Total Pending Amount</span>
                <span class="summary-value">₹{{ emiSummary.totalPendingAmount | number:'1.2-2' }}</span>
              </div>
              <div class="summary-item">
                <span class="summary-label">Next Due Amount</span>
                <span class="summary-value">₹{{ emiSummary.nextDueAmount | number:'1.2-2' }}</span>
              </div>
            </div>
          </div>
          
          <!-- EMI Tabs -->
          <div class="emi-tabs">
            <button 
              class="emi-tab" 
              [class.active]="activeEmiTab === 'all'"
              (click)="switchEmiTab('all')">
              All EMIs ({{ emis.length }})
            </button>
            <button 
              class="emi-tab" 
              [class.active]="activeEmiTab === 'paid'"
              (click)="switchEmiTab('paid')">
              Paid ({{ emiSummary?.paidEmis || 0 }})
            </button>
            <button 
              class="emi-tab" 
              [class.active]="activeEmiTab === 'upcoming'"
              (click)="switchEmiTab('upcoming')">
              Upcoming ({{ getUpcomingEmiCount() }})
            </button>
          </div>
          
          <!-- EMI Filters -->
          <div class="emi-filters">
            <div class="filter-group">
              <label>Financial Year:</label>
              <select [(ngModel)]="emiFilters.financialYear" (change)="applyEMIFilters()">
                <option value="">All Years</option>
                <option *ngFor="let year of financialYears" [value]="year">{{ year }}</option>
              </select>
            </div>
            
            <div class="filter-group">
              <label>Status:</label>
              <select [(ngModel)]="emiFilters.status" (change)="applyEMIFilters()">
                <option value="all">All Status</option>
                <option value="paid">Paid</option>
                <option value="pending">Pending</option>
                <option value="failed">Failed</option>
                <option value="overdue">Overdue</option>
              </select>
            </div>
            
            <div class="filter-group">
              <label>Month:</label>
              <select [(ngModel)]="emiFilters.month" (change)="applyEMIFilters()">
                <option *ngFor="let month of months" [value]="month.value">{{ month.label }}</option>
              </select>
            </div>
            
            <div class="filter-group">
              <label>Search:</label>
              <input 
                type="text" 
                [(ngModel)]="emiFilters.searchTerm" 
                (input)="applyEMIFilters()"
                placeholder="Loan Account, EMI #...">
            </div>
            
            <button (click)="resetEMIFilters()" class="reset-filters-btn">Reset Filters</button>
          </div>
          
          <div *ngIf="isLoadingEMIs" class="loading-state">Loading EMIs...</div>
          
          <div *ngIf="!isLoadingEMIs && filteredEmis.length === 0" class="empty-state">
            <p>No EMIs found matching your filters.</p>
          </div>
          
          <div *ngIf="!isLoadingEMIs && filteredEmis.length > 0" class="emis-list">
            <div class="emi-count-info">
              Showing {{ filteredEmis.length }} of {{ emis.length }} EMIs
            </div>
            <div *ngFor="let emi of filteredEmis" class="emi-card" [ngClass]="getEMIStatusClass(emi.status)">
              <div class="card-header">
                <h3>EMI #{{ emi.emiNumber }} - {{ emi.loanAccountNumber }}</h3>
                <span class="status-badge" [ngClass]="getEMIStatusClass(emi.status)">
                  {{ emi.status }}
                  <span *ngIf="isEMIOverdue(emi)" class="overdue-badge">OVERDUE</span>
                </span>
              </div>
              <div class="card-body">
                <div class="info-row">
                  <span class="label">Due Date:</span>
                  <span class="value" [ngClass]="isEMIOverdue(emi) ? 'overdue' : ''">
                    {{ emi.dueDate | date:'dd/MM/yyyy' }}
                  </span>
                </div>
                <div class="info-row">
                  <span class="label">Total Amount:</span>
                  <span class="value highlight">₹{{ emi.totalAmount | number:'1.2-2' }}</span>
                </div>
                <div class="info-row">
                  <span class="label">Principal:</span>
                  <span class="value">₹{{ emi.principalAmount | number:'1.2-2' }}</span>
                </div>
                <div class="info-row">
                  <span class="label">Interest:</span>
                  <span class="value">₹{{ emi.interestAmount | number:'1.2-2' }}</span>
                </div>
                <div class="info-row" *ngIf="emi.remainingPrincipal">
                  <span class="label">Remaining Principal:</span>
                  <span class="value">₹{{ emi.remainingPrincipal | number:'1.2-2' }}</span>
                </div>
                <div class="info-row" *ngIf="emi.paymentDate">
                  <span class="label">Paid On:</span>
                  <span class="value">{{ emi.paymentDate | date:'dd/MM/yyyy' }}</span>
                </div>
              </div>
              <div class="card-footer" *ngIf="emi.status === 'Pending' || emi.status === 'PENDING'">
                <button (click)="payEMI(emi.id)" class="pay-emi-btn">Pay EMI</button>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Accounts Feature -->
        <div *ngIf="selectedFeature === 'accounts'">
          <div class="feature-header">
            <h2>Account Details</h2>
            <button (click)="loadUserProfile()" class="action-btn">Refresh</button>
          </div>
          <div class="accounts-section">
            <div class="account-card">
              <div class="account-header">
                <h3>Account Information</h3>
              </div>
              <div class="account-details">
                <div class="detail-row">
                  <span class="detail-label">Account Number:</span>
                  <span class="detail-value">{{ userAccountNumber }}</span>
                </div>
                <div class="detail-row">
                  <span class="detail-label">Account Holder:</span>
                  <span class="detail-value">{{ username }}</span>
                </div>
                <div class="detail-row">
                  <span class="detail-label">Current Balance:</span>
                  <span class="detail-value balance">₹{{ currentBalance | number:'1.2-2' }}</span>
                </div>
                <div class="detail-row" *ngIf="userProfile?.email">
                  <span class="detail-label">Email:</span>
                  <span class="detail-value">{{ userProfile.email }}</span>
                </div>
              </div>
              <div class="account-actions">
                <button (click)="selectFeature('transaction')" class="btn-secondary">View Transactions</button>
                <button (click)="selectFeature('transferfunds')" class="btn-primary">Transfer Funds</button>
              </div>
            </div>
          </div>
        </div>

        <!-- Transfer Funds Feature -->
