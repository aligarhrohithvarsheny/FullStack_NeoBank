        <!-- Support Tickets Feature -->
        <div *ngIf="selectedFeature === 'support-tickets'" class="embedded-feature">
          <app-support-tickets></app-support-tickets>
        </div>

        <!-- Bank Messages Feature -->
        <div *ngIf="selectedFeature === 'bank-messages'" class="embedded-feature">
          <app-bank-messages></app-bank-messages>
