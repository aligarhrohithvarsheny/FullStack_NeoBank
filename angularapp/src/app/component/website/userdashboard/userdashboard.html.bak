          <app-card></app-card>
        </div>

        <!-- Credit Card Feature -->
        <div *ngIf="selectedFeature === 'credit-card'" class="embedded-feature">
          <app-creditcard></app-creditcard>
        </div>

        <!-- Loan Feature -->
        <div *ngIf="selectedFeature === 'loan'" class="embedded-feature">
          <app-loan></app-loan>
        </div>

        <!-- Cheque Feature -->
        <div *ngIf="selectedFeature === 'cheque'" class="embedded-feature">
          <app-cheque></app-cheque>
        </div>

        <!-- KYC Update Feature -->
        <div *ngIf="selectedFeature === 'kycupdate'" class="embedded-feature">
          <app-kycupdate></app-kycupdate>
        </div>

        <!-- Gold Loan Feature -->
        <div *ngIf="selectedFeature === 'goldloan'" class="embedded-feature">
          <app-goldloan></app-goldloan>
        </div>

        <!-- Subsidy Claim Feature -->
        <div *ngIf="selectedFeature === 'subsidy-claim'" class="embedded-feature">
          <app-subsidy-claim></app-subsidy-claim>
        </div>

        <!-- Bill Payment Feature -->
        <div *ngIf="selectedFeature === 'bill-payment'" class="embedded-feature">
          <app-billpayment></app-billpayment>
        </div>

        <!-- Scheduled Payments Feature -->
        <div *ngIf="selectedFeature === 'scheduled-payments'" class="embedded-feature">
